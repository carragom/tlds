{
	"name": "@carragom/tlds",
	"version": "0.0.1-alpha.3",
	"exports": {
		".": "./src/mod.ts"
	},
	"license": "MIT",
	"lock": false,
	"fmt": {
		"useTabs": true,
		"indentWidth": 3,
		"singleQuote": true,
		"semiColons": false,
		"exclude": [
			"data/*"
		]
	},
	"lint": {
		"rules": {
			"tags": ["recommended", "jsr"],
			"include": [
				"camelcase",
				"no-sync-fn-in-async-fn",
				"single-var-declarator"
			]
		}
	},
	"test": {
		"permissions": {
			"read": true,
			"write": true
		}
	},
	"tasks": {
		"fetch": {
			"command": "deno run --allow-net=www.iana.org:443 src/cli.ts fetch",
			"description": "Fetch the IANA TLD dataset and prints it to stdout in the default output format (TSV). Use --format csv|json for a different format."
		},
		"update": {
			"command": "deno run --allow-net=www.iana.org:443 --allow-write=data --allow-read=data src/cli.ts update",
			"description": "Fetch the IANA TLD dataset and updates the local dataset files data/*."
		},
		"install": {
			"command": "deno install --global --allow-net=www.iana.org:443 --allow-write=data --allow-read=data -n tlds src/cli.ts"
		},
		"test": "deno test -P"
	},
	"imports": {
		"@b-fuze/deno-dom": "jsr:@b-fuze/deno-dom@^0.1.56",
		"@std/assert": "jsr:@std/assert@1",
		"@std/cli": "jsr:@std/cli@1",
		"@std/csv": "jsr:@std/csv@1",
		"@std/fs": "jsr:@std/fs@1",
		"@std/path": "jsr:@std/path@1"
	}
}
